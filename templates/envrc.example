# claude-code-multi-account: per-directory account override
# Copy to the root of a work tree (e.g. ~/work/.envrc), then run: direnv allow
#
# Fail-closed: if the token can't be read, this aborts the .envrc rather than letting
# Claude Code silently fall back to the shared keychain (= wrong account).

# The ONLY thing you change per account. Derives the config dir + keychain item below.
# Convention: PROFILE "acme" -> ~/.claude-acme + keychain item "Claude-acme-Token".
# Must match the dir/item you used when minting the token (see README step 2).
PROFILE="work"

export CLAUDE_CONFIG_DIR="$HOME/.claude-$PROFILE"
export CLAUDE_CODE_OAUTH_TOKEN="$(security find-generic-password -s "Claude-$PROFILE-Token" -w 2>/dev/null)"

if [ -z "$CLAUDE_CODE_OAUTH_TOKEN" ]; then
  echo "claude-code-multi-account: '$PROFILE' token missing from keychain (Claude-$PROFILE-Token)" >&2
  echo "  re-mint with: CLAUDE_CONFIG_DIR=$CLAUDE_CONFIG_DIR claude setup-token" >&2
  exit 1
fi

# If this seat is API-key or Bedrock/Vertex backed instead of setup-token OAuth,
# replace the token export above with one of:
#   export ANTHROPIC_API_KEY="$(security find-generic-password -s "Claude-$PROFILE-Key" -w)"
#   export CLAUDE_CODE_USE_BEDROCK=1   # (+ AWS creds / region)
